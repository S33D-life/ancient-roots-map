# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment files (never commit secrets)
.env
.env.*
.env.production
!.env.example
!.env.example.*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Vite temp files
vite.config.ts.timestamp-*.mjs
.vite/

# Build-generated version metadata — written by `node generate-version.mjs`
# at build time (see package.json "build"). Regenerated every build; runtime
# fetch + vite resolveBuildId() both degrade gracefully when absent in dev.
public/version.json

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
