# Cache headers for Lovable/Netlify/Vercel-style hosting
# Production CSP (no unsafe-eval)
/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self' https://lovable.dev https://*.lovable.dev https://lovable.app https://*.lovable.app https://*.lovableproject.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self'; connect-src 'self' https: wss:; worker-src 'self' blob:; manifest-src 'self'

# index.html — never cache aggressively
/index.html
  Cache-Control: no-cache, must-revalidate

# Service worker — always revalidate
/sw.js
  Cache-Control: no-cache, must-revalidate

# Version check — always fresh
/version.json
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed assets — cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable
